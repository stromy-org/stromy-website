---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleContent from '../../components/content/ArticleLayout.astro';
import CaseStudyCard from '../../components/content/CaseStudyCard.astro';
import StatBlock from '../../components/ui/StatBlock.astro';
import ScoreLine from '../../components/ui/ScoreLine.astro';

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies');
  return caseStudies.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Related case studies: same capability, exclude self
const allCaseStudies = await getCollection('case-studies');
const related = allCaseStudies
  .filter((cs) => cs.data.capability === entry.data.capability && cs.id !== entry.id)
  .slice(0, 3);
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  date={new Date()}
  image={entry.data.image.src}
>
  <!-- Metrics ribbon -->
  {entry.data.metrics && entry.data.metrics.length > 0 && (
    <section class="mb-12 rounded-xl bg-secondary p-8">
      <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
        {entry.data.metrics.map((metric) => (
          <div class="text-center">
            <StatBlock
              value={metric.value}
              label={metric.label}
              class="items-center [&>span:first-child]:text-accent [&>span:last-child]:text-ash"
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Score line -->
  <div class="mx-auto mb-12 max-w-xs">
    <ScoreLine variant="full" />
  </div>

  <!-- MDX content -->
  <ArticleContent>
    <Content />
  </ArticleContent>

  <!-- Related case studies -->
  {related.length > 0 && (
    <section class="mt-20">
      <div class="mx-auto mb-12 max-w-xs">
        <ScoreLine variant="full" />
      </div>
      <h2 class="display-lg mb-8 text-center text-primary">Related Case Studies</h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {related.map((cs) => (
          <CaseStudyCard
            title={cs.data.title}
            capability={cs.data.capability}
            client={cs.data.client}
            slug={cs.id}
            image={cs.data.image}
            region={cs.data.region}
            metrics={cs.data.metrics}
          />
        ))}
      </div>
    </section>
  )}
</ArticleLayout>
