---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import CaseStudyCard from '../../components/content/CaseStudyCard.astro';
import ScoreLine from '../../components/ui/ScoreLine.astro';
import Badge from '../../components/ui/Badge.astro';

const caseStudies = await getCollection('case-studies');

// Extract unique regions for filtering
const regions = [...new Set(caseStudies.map((cs) => cs.data.region))].sort();
---

<PageLayout
  title="Case Studies — Stromy"
  description="Explore how Stromy's orchestrated intelligence platform delivers measurable outcomes across government relations, crisis management, and strategic communications."
>
  <section class="bg-background py-24 md:py-30">
    <div class="mx-auto max-w-7xl px-6">
      <div class="fade-up max-w-3xl">
        <p class="section-kicker">Case studies</p>
        <h1 class="display-xl mt-6 text-primary">Evidence of how the system performs in the field.</h1>
        <p class="section-lead body-lg mt-6">
          Selected work showing how Stromy turns complex information environments into
          clearer strategic action.
        </p>
      </div>

      <div class="fade-up mt-10 mb-12 max-w-xs">
        <ScoreLine variant="full" animated />
      </div>

      <div class="fade-up mb-12 flex flex-wrap items-center gap-3">
        <button
          class="region-filter active"
          data-region="all"
          aria-pressed="true"
        >
          <Badge text="All" variant="primary" />
        </button>
        {regions.map((region) => (
          <button
            class="region-filter"
            data-region={region}
            aria-pressed="false"
          >
            <Badge text={region.toUpperCase()} variant="muted" />
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3" id="case-study-grid">
        {caseStudies.map((cs) => (
          <div class="fade-up case-study-item" data-region={cs.data.region}>
            <CaseStudyCard
              title={cs.data.title}
              capability={cs.data.capability}
              client={cs.data.client}
              slug={cs.id}
              image={cs.data.image}
              region={cs.data.region}
              metrics={cs.data.metrics}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const filters = document.querySelectorAll('.region-filter');
    const items = document.querySelectorAll('.case-study-item');

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        const region = (btn as HTMLElement).dataset.region;

        // Update active state
        filters.forEach((f) => f.classList.remove('active'));
        btn.classList.add('active');

        // Filter items
        items.forEach((item) => {
          const el = item as HTMLElement;
          if (region === 'all' || el.dataset.region === region) {
            el.style.display = '';
          } else {
            el.style.display = 'none';
          }
        });
      });
    });
  });
</script>

<style>
  .region-filter {
    cursor: pointer;
    background: none;
    border: 1px solid rgba(11, 11, 11, 0.08);
    border-radius: 999px;
    padding: 0;
    transition: border-color 0.2s, background-color 0.2s, transform 0.2s;
  }

  .region-filter.active {
    background-color: rgba(27, 61, 51, 0.08);
    border-color: rgba(27, 61, 51, 0.18);
  }

  .region-filter:hover {
    transform: translateY(-1px);
  }
</style>
