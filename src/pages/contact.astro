---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import ScoreLine from '../components/ui/ScoreLine.astro';

const offices = [
  {
    region: 'Australia',
    city: 'Melbourne',
    email: 'hello@stromy.com.au',
  },
  {
    region: 'Netherlands',
    city: 'Amsterdam',
    email: 'hello@stromy.nl',
  },
];
---

<PageLayout
  title="Contact — Stromy"
  description="Get in touch with Stromy. Offices in Melbourne and Amsterdam."
>
  <section class="bg-background py-24 md:py-30">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
        <div class="fade-up">
          <p class="section-kicker">Contact</p>
          <h1 class="display-xl mt-6 max-w-3xl text-primary">Talk to Stromy about your intelligence environment.</h1>
          <p class="section-lead body-lg mt-6">
            Reach out to the team in Melbourne or Amsterdam. We work with organisations
            navigating policy, media, and stakeholder complexity.
          </p>
          <div class="mt-10 max-w-xs">
            <ScoreLine variant="full" animated />
          </div>
        </div>

        <div class="fade-up dark-panel rounded-[2rem] p-8 text-background">
          <p class="font-mono text-[0.72rem] uppercase tracking-[0.22em] text-background/52">
            What to expect
          </p>
          <div class="mt-6 grid gap-4 text-sm leading-7 text-background/70">
            <div class="border-l border-accent/70 pl-4">A direct response from the core team.</div>
            <div class="border-l border-accent/70 pl-4">Discussion focused on your information environment, not generic tooling.</div>
            <div class="border-l border-accent/70 pl-4">Options for advisory, monitoring, and workflow design.</div>
          </div>
        </div>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-2">
        {offices.map((office) => (
          <Card class="fade-up text-center">
            <h2 class="display-md mb-2 text-primary">{office.region}</h2>
            <p class="body-lg mb-6 text-text-light">{office.city}</p>

            <Button variant="accent" href={`mailto:${office.email}`} size="lg">
              {office.email}
            </Button>

            <button
              class="copy-email mt-4 block w-full text-center"
              data-email={office.email}
            >
              <span class="mono text-sm text-text-light underline decoration-dotted underline-offset-4 hover:text-accent">
                Copy email address
              </span>
            </button>
          </Card>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.copy-email').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const email = (btn as HTMLElement).dataset.email;
        if (!email) return;

        try {
          await navigator.clipboard.writeText(email);
          const span = btn.querySelector('span');
          if (span) {
            const original = span.textContent;
            span.textContent = 'Copied!';
            setTimeout(() => {
              span.textContent = original;
            }, 2000);
          }
        } catch {
          // Fallback: select text from a temporary input
          const input = document.createElement('input');
          input.value = email;
          document.body.appendChild(input);
          input.select();
          document.execCommand('copy');
          document.body.removeChild(input);

          const span = btn.querySelector('span');
          if (span) {
            const original = span.textContent;
            span.textContent = 'Copied!';
            setTimeout(() => {
              span.textContent = original;
            }, 2000);
          }
        }
      });
    });
  });
</script>
