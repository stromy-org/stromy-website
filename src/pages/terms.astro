---
import PageLayout from '../layouts/PageLayout.astro';
import ArticleContent from '../components/content/ArticleLayout.astro';
---

<PageLayout
  title="Terms of Service — Stromy"
  description="Terms of service for Stromy."
>
  <section class="bg-background py-24 md:py-30">
    <div class="mx-auto max-w-4xl px-6">
      <p class="section-kicker">Legal</p>
      <h1 class="display-xl mt-6 text-primary">Terms of Service</h1>
      <p class="body-lg mt-6 text-text-light">
        This page provides a proper legal destination until the final terms are supplied.
      </p>

      <div class="mt-10 rounded-[2rem] bg-background-alt px-6 py-8 md:px-8">
        <ArticleContent>
          <h2>Use of the Site</h2>
          <p>
            The Stromy website is provided for informational purposes. Content may change
            without notice.
          </p>
          <h2>No Reliance</h2>
          <p>
            Material on this site should not be treated as legal, strategic, or regulatory
            advice without direct engagement and review.
          </p>
          <h2>Intellectual Property</h2>
          <p>
            Unless otherwise stated, site content and branding remain the property of Stromy.
          </p>
          <h2>Contact</h2>
          <p>
            Questions about these terms can be sent to <a href="mailto:hello@stromy.com.au">hello@stromy.com.au</a>.
          </p>
        </ArticleContent>
      </div>
    </div>
  </section>
</PageLayout>
