---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Card from '../../components/ui/Card.astro';
import ScoreLine from '../../components/ui/ScoreLine.astro';
import Icon from '../../components/ui/Icon.astro';

const capabilities = (await getCollection('capabilities')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<PageLayout
  title="Capabilities — Stromy"
  description="Explore Stromy's AI-powered capabilities across government relations, crisis management, media relations, and strategic communications."
>
  <section class="bg-background py-24 md:py-30">
    <div class="mx-auto max-w-7xl px-6">
      <div class="fade-up max-w-3xl">
        <p class="section-kicker">Capabilities</p>
        <h1 class="display-xl mt-6 text-primary">A capability set designed for live information environments.</h1>
        <p class="section-lead body-lg mt-6">
          Stromy combines AI-assisted research, structured workflows, and expert judgement
          across the core disciplines of strategic communication.
        </p>
      </div>

      <div class="fade-up mt-10 mb-12 max-w-xs">
        <ScoreLine variant="full" animated />
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
        {capabilities.map((cap) => (
          <Card href={`/capabilities/${cap.id}`} class="fade-up h-full">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-[1.15rem] bg-background-alt text-primary">
              <Icon name={cap.data.icon} size={24} />
            </div>
            <h2 class="display-sm mb-3 text-primary">{cap.data.title}</h2>
            <p class="body-md mb-5 text-text-light">{cap.data.description}</p>
            <span class="mono mt-auto inline-flex items-center text-[0.74rem] uppercase tracking-[0.18em] text-accent">
              Explore capability
            </span>
          </Card>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
