---
import PageLayout from '../layouts/PageLayout.astro';
import ArticleContent from '../components/content/ArticleLayout.astro';
---

<PageLayout
  title="Privacy Policy — Stromy"
  description="Privacy policy for Stromy."
>
  <section class="bg-background py-24 md:py-30">
    <div class="mx-auto max-w-4xl px-6">
      <p class="section-kicker">Legal</p>
      <h1 class="display-xl mt-6 text-primary">Privacy Policy</h1>
      <p class="body-lg mt-6 text-text-light">
        This placeholder policy gives the site a real destination for privacy links until
        the final legal copy is approved.
      </p>

      <div class="mt-10 rounded-[2rem] bg-background-alt px-6 py-8 md:px-8">
        <ArticleContent>
          <h2>Information We Receive</h2>
          <p>
            If you contact Stromy, we may receive your name, organisation, and the details
            you provide in your message.
          </p>
          <h2>How We Use It</h2>
          <p>
            We use submitted information to respond to enquiries, evaluate potential work,
            and improve how we operate the site.
          </p>
          <h2>Retention</h2>
          <p>
            We keep information only for as long as it is reasonably needed for operational,
            legal, or security purposes.
          </p>
          <h2>Contact</h2>
          <p>
            For privacy-related questions, contact <a href="mailto:hello@stromy.com.au">hello@stromy.com.au</a>.
          </p>
        </ArticleContent>
      </div>
    </div>
  </section>
</PageLayout>
