---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/content/BlogCard.astro';
import ScoreLine from '../../components/ui/ScoreLine.astro';
import NewsletterSignup from '../../components/sections/NewsletterSignup.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const featuredPost = posts.find((p) => p.data.featured) ?? posts[0];
const remainingPosts = posts.filter((p) => p.id !== featuredPost?.id);
---

<PageLayout
  title="Insights — Stromy"
  description="Analysis and perspectives on AI, government relations, crisis management, and strategic communications from the Stromy team."
>
  <section class="bg-background py-24 md:py-30">
    <div class="mx-auto max-w-7xl px-6">
      <div class="fade-up max-w-3xl">
        <p class="section-kicker">Insights</p>
        <h1 class="display-xl mt-6 text-primary">Analysis and perspective for high-stakes communication environments.</h1>
        <p class="section-lead body-lg mt-6">
          Essays, case notes, and commentary on AI, government relations, crisis
          management, and strategic communications.
        </p>
      </div>

      <div class="fade-up mt-10 mb-12 max-w-xs">
        <ScoreLine variant="full" animated />
      </div>

      {featuredPost && (
        <div class="fade-up mb-16">
          <BlogCard
            title={featuredPost.data.title}
            description={featuredPost.data.description}
            date={featuredPost.data.date}
            slug={featuredPost.id}
            image={featuredPost.data.image}
            region={featuredPost.data.region}
            featured={true}
          />
        </div>
      )}

      {remainingPosts.length > 0 && (
        <>
          <div class="fade-up mb-10 flex items-center gap-4">
            <ScoreLine variant="short" />
            <h2 class="display-md text-primary">More insights</h2>
          </div>
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
          {remainingPosts.map((post) => (
            <div class="fade-up">
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                slug={post.id}
                image={post.data.image}
                region={post.data.region}
              />
            </div>
          ))}
          </div>
        </>
      )}
    </div>
  </section>

  <NewsletterSignup />
</PageLayout>
