---
import PageLayout from '../layouts/PageLayout.astro';
import Card from '../components/ui/Card.astro';
import ScoreLine from '../components/ui/ScoreLine.astro';
import Button from '../components/ui/Button.astro';
import CTABand from '../components/sections/CTABand.astro';
import { team } from '../data/team';

const values = [
  {
    name: 'Precise',
    description: 'Every insight is grounded in verifiable data. We prioritise accuracy over speed, substance over noise.',
  },
  {
    name: 'Authoritative',
    description: 'We speak with the confidence that comes from deep domain expertise and rigorous methodology.',
  },
  {
    name: 'Resourceful',
    description: 'We find the signal in complexity. Our platform connects disparate data sources into coherent intelligence.',
  },
  {
    name: 'Unflinching',
    description: 'We deliver the full picture, not just the comfortable parts. Honest counsel drives better decisions.',
  },
  {
    name: 'Grounded',
    description: 'Technology serves strategy, not the other way around. Every capability exists to solve a real problem.',
  },
];

const sectors = [
  'Government & Public Sector',
  'Energy & Resources',
  'Infrastructure & Transport',
  'Technology & Telecommunications',
  'Financial Services',
  'Health & Life Sciences',
];
---

<PageLayout
  title="About — Stromy"
  description="Learn about Stromy's mission, team, values, and approach to orchestrated intelligence for strategic communications."
>
  <section class="bg-background py-24 md:py-30">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div class="fade-up">
          <p class="section-kicker">About</p>
          <h1 class="display-xl mt-6 max-w-3xl text-primary">Built for teams that need signal, not noise.</h1>
          <p class="section-lead body-lg mt-6">
            Stromy builds intelligence systems for organisations navigating complex
            stakeholder environments, volatile media cycles, and public-sector scrutiny.
          </p>
          <div class="mt-10">
            <Button variant="outline" href="/contact">
              Talk to the team
            </Button>
          </div>
        </div>

        <div class="fade-up dark-panel rounded-[2rem] p-8 text-background">
          <p class="font-mono text-[0.72rem] uppercase tracking-[0.22em] text-background/52">
            Operating principles
          </p>
          <div class="mt-6 grid gap-5">
            {values.slice(0, 3).map((value) => (
              <div class="border-l border-accent/70 pl-4">
                <h2 class="display-sm text-background">{value.name}</h2>
                <p class="mt-2 text-sm leading-7 text-background/72">{value.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background py-10 md:py-14">
    <div class="mx-auto max-w-7xl px-6">
      <div class="fade-up mb-12 flex items-center gap-4">
        <ScoreLine variant="short" />
        <h2 class="display-md text-primary">Our values</h2>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {values.map((v) => (
          <Card class="fade-up h-full">
            <h3 class="display-sm mb-3 text-primary">{v.name}</h3>
            <p class="body-md text-text-light">{v.description}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-background-alt py-24 md:py-28" id="team">
    <div class="mx-auto max-w-7xl px-6">
      <div class="fade-up mb-12 max-w-2xl">
        <p class="section-kicker">Team</p>
        <h2 class="display-lg mt-6 text-primary">A small team with a high-judgement brief.</h2>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {team.map((member) => (
          <Card class="fade-up h-full">
            <div class="mb-5 flex h-18 w-18 items-center justify-center rounded-[1.4rem] bg-primary">
              <span class="text-2xl font-semibold text-background">
                {member.name.split(' ').map((n) => n[0]).join('')}
              </span>
            </div>
            <h3 class="display-sm mb-2 text-primary">{member.name}</h3>
            <p class="mono mb-4 text-[0.74rem] uppercase tracking-[0.18em] text-accent">{member.role}</p>
            <p class="body-md text-text-light">{member.bio}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-background py-24 md:py-28">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
        <Card class="fade-up">
          <p class="section-kicker">Partner network</p>
          <h2 class="display-md mt-6 text-primary">AMARIS</h2>
          <p class="body-md mt-4 text-text-light">
            Strategic partner for integrated communications and public affairs across
            Australia and the Netherlands.
          </p>
        </Card>
        <div class="fade-up grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
          {sectors.map((sector) => (
            <Card class="h-full">
              <h3 class="display-sm text-primary">{sector}</h3>
            </Card>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTABand />
</PageLayout>
