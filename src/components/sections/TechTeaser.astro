---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

const pillars = [
  {
    icon: 'sparkles',
    name: 'Plugins & Skills',
    description: 'Reusable capability layers that encode expert methodology into repeatable operating patterns.',
  },
  {
    icon: 'database-zap',
    name: 'MCP Data Connectors',
    description: 'Live access to government, media, and regulatory sources without manual stitching.',
  },
  {
    icon: 'workflow',
    name: 'LangGraph Workflows',
    description: 'Multi-step flows that turn collection, analysis, and reporting into one reliable sequence.',
  },
  {
    icon: 'library-big',
    name: 'Research Centre',
    description: 'A durable intelligence layer where outputs can be revisited, compared, and operationalised.',
  },
];
---

<section class="bg-secondary py-24 text-background md:py-30">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr]">
      <div class="fade-up">
        <p class="section-kicker text-background/56 before:bg-background/24">Platform</p>
        <h2 class="display-lg mt-6 text-background">Powered by orchestrated intelligence.</h2>
        <p class="body-lg mt-6 max-w-xl text-background/72">
          Stromy combines AI agents, live data connectors, and structured workflows into
          one operating layer for teams that need speed, traceability, and better signal.
        </p>
        <div class="mt-10">
          <Button variant="accent" href="/technology" size="lg">
            Explore the platform
          </Button>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
      {pillars.map((pillar) => (
        <div class="fade-up rounded-[1.75rem] border border-white/10 bg-white/[0.04] p-7">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-[1.1rem] bg-background text-primary">
            <Icon name={pillar.icon} size={22} />
          </div>
          <h3 class="display-sm mb-3 text-background">{pillar.name}</h3>
          <p class="body-md text-background/68">{pillar.description}</p>
        </div>
      ))}
      </div>
    </div>
  </div>
</section>
