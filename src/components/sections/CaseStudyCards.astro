---
import { getCollection } from 'astro:content';
import CaseStudyCard from '../content/CaseStudyCard.astro';
import Button from '../ui/Button.astro';

interface Props {
  region?: 'au' | 'nl' | 'all';
}

const { region = 'all' } = Astro.props;

const caseStudies = await getCollection('case-studies');

const filtered = region === 'all'
  ? caseStudies
  : caseStudies.filter((cs) => cs.data.region === region);
---

<section class="bg-background-alt py-24 md:py-30">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="fade-up max-w-2xl">
        <p class="section-kicker">Case studies</p>
        <h2 class="display-lg mt-6 text-primary">Real work, grounded in outcomes.</h2>
        <p class="section-lead body-lg mt-6">
          A sample of how Stromy turns fragmented public signals into usable strategic
          intelligence for communications and stakeholder teams.
        </p>
      </div>
      <div class="fade-up">
        <Button variant="outline" href="/case-studies">
          View all case studies
        </Button>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
      {filtered.map((study) => (
        <div class="fade-up">
          <CaseStudyCard
            title={study.data.title}
            capability={study.data.capability}
            client={study.data.client}
            slug={study.id}
            image={study.data.image}
            region={study.data.region}
            metrics={study.data.metrics}
          />
        </div>
      ))}
    </div>
  </div>
</section>
