---
import { getCollection } from 'astro:content';
import Card from '../ui/Card.astro';
import Icon from '../ui/Icon.astro';

const capabilities = (await getCollection('capabilities'))
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="bg-background py-24 md:py-30">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr]">
      <div class="fade-up lg:sticky lg:top-30">
        <p class="section-kicker">Capabilities</p>
        <h2 class="display-lg mt-6 max-w-xl text-primary">What Stromy is built to do.</h2>
        <p class="section-lead body-lg mt-6">
          Each capability combines domain expertise, AI-assisted research, and a workflow
          architecture designed for teams operating in high-stakes information environments.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {capabilities.map((cap) => (
        <Card href={`/capabilities/${cap.id}`} class="fade-up group h-full">
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-[1.15rem] bg-background-alt text-primary">
            <Icon name={cap.data.icon} size={24} />
          </div>
          <h3 class="display-sm mb-3 text-primary">{cap.data.title}</h3>
          <p class="body-md mb-5 text-text-light">{cap.data.description}</p>
          <span class="mono mt-auto inline-flex items-center text-[0.74rem] font-medium uppercase tracking-[0.18em] text-accent">
            Explore capability
          </span>
        </Card>
      ))}
      </div>
    </div>
  </div>
</section>
