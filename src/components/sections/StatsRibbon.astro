---
import StatBlock from '../ui/StatBlock.astro';
import ScoreLine from '../ui/ScoreLine.astro';
import { stats } from '../../data/stats';
---

<section class="bg-background py-8 md:py-12">
  <div class="mx-auto max-w-7xl px-6">
    <div class="dark-panel rounded-[2rem] px-6 py-8 md:px-10 md:py-10">
      <div class="mb-10 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="fade-up">
          <p class="section-kicker text-background/54 before:bg-background/24">At a glance</p>
          <h2 class="display-sm mt-5 text-background">Proof, not posture.</h2>
        </div>
        <p class="fade-up max-w-2xl text-sm leading-7 text-background/68 md:text-base">
          The platform is designed to compress research time, widen coverage, and help
          communication teams move from scattered monitoring to structured intelligence.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-0">
        {stats.map((stat, i) => (
          <div class:list={[
            'fade-up relative flex flex-col items-start text-left md:px-6',
            i < stats.length - 1 && 'md:border-r md:border-white/8',
          ]}>
            <StatBlock
              value={stat.value}
              label={stat.label}
              suffix={stat.suffix}
              class="[&>span:first-child]:text-accent [&>span:last-child]:text-background/58"
            />
            {i < stats.length - 1 && (
              <div class="absolute -right-px top-1/2 hidden -translate-y-1/2 md:block">
                <ScoreLine variant="short" class="rotate-90 [&_div]:bg-white/12" />
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
