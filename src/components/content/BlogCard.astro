---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  image: ImageMetadata;
  region: string;
  featured?: boolean;
}

const { title, description, date, slug, image, region, featured = false } = Astro.props;

const formattedDate = date.toLocaleDateString("en-AU", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const cardClasses = featured ? "col-span-full md:col-span-2" : "";
const imageHeight = featured ? "h-64 md:h-80" : "h-48";
---

<Card href={`/blog/${slug}`} class={cardClasses}>
  <div class="flex flex-col gap-4">
    {/* Image with brutalist overlay */}
    <div class:list={["brutalist-overlay overflow-hidden rounded-lg", imageHeight]}>
      <Image
        src={image}
        alt={title}
        class="h-full w-full object-cover"
        widths={featured ? [640, 960, 1280] : [400, 640]}
        sizes={featured
          ? "(max-width: 768px) 100vw, 66vw"
          : "(max-width: 768px) 100vw, 33vw"}
      />
    </div>

    {/* Meta row */}
    <div class="flex items-center gap-3">
      <time datetime={date.toISOString()} class="body-sm text-text-light">
        {formattedDate}
      </time>
      <Badge text={region} variant="muted" />
    </div>

    {/* Title */}
    <h3 class:list={[featured ? "display-md" : "display-sm", "text-primary"]}>
      {title}
    </h3>

    {/* Description */}
    <p class:list={[featured ? "body-lg" : "body-md", "text-text-light line-clamp-3"]}>
      {description}
    </p>
  </div>
</Card>
