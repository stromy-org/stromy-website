---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";
import Icon from "../ui/Icon.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  image: ImageMetadata;
  region: string;
  featured?: boolean;
}

const { title, description, date, slug, image, region, featured = false } = Astro.props;

const formattedDate = date.toLocaleDateString("en-AU", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const cardClasses = featured ? "col-span-full lg:col-span-2" : "";
const imageHeight = featured ? "h-72 md:h-[25rem]" : "h-56";
---

<Card href={`/blog/${slug}`} class={cardClasses}>
  <div class="flex h-full flex-col gap-5">
    <div class:list={["brutalist-overlay overflow-hidden rounded-[1.35rem]", imageHeight]}>
      <Image
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
        widths={featured ? [640, 960, 1280] : [400, 640]}
        sizes={featured
          ? "(max-width: 768px) 100vw, 66vw"
          : "(max-width: 768px) 100vw, 33vw"}
      />
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <time datetime={date.toISOString()} class="body-sm text-text-light">
        {formattedDate}
      </time>
      <Badge text={region} variant="muted" />
    </div>

    <h3 class:list={[featured ? "display-md" : "display-sm", "max-w-3xl text-primary"]}>
      {title}
    </h3>

    <p class:list={[featured ? "body-lg max-w-2xl" : "body-md", "text-text-light line-clamp-3"]}>
      {description}
    </p>

    <div class="mt-auto flex items-center gap-2 font-mono text-[0.74rem] uppercase tracking-[0.18em] text-primary">
      Read article
      <Icon name="sparkles" size={16} class="text-accent" />
    </div>
  </div>
</Card>
