---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";
import Icon from "../ui/Icon.astro";

interface Props {
  title: string;
  capability: string;
  client: string;
  slug: string;
  image: ImageMetadata;
  region: string;
  metrics?: { label: string; value: string }[];
}

const { title, capability, client, slug, image, region, metrics = [] } = Astro.props;

const firstMetric = metrics.length > 0 ? metrics[0] : null;
---

<Card href={`/case-studies/${slug}`} class="group h-full">
  <div class="flex h-full flex-col gap-5">
    <div class="brutalist-overlay h-60 overflow-hidden rounded-[1.35rem]">
      <Image
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
        widths={[400, 640]}
        sizes="(max-width: 768px) 100vw, 33vw"
      />
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <Badge text={capability} variant="primary" />
      <Badge text={region} variant="muted" />
    </div>

    <h3 class="display-sm text-primary">{title}</h3>

    <p class="body-sm text-text-light">{client}</p>

    {firstMetric && (
      <div class="mt-auto rounded-[1.15rem] border border-black/6 bg-black/[0.025] px-4 py-4">
        <p class="mono text-xs uppercase tracking-wider text-text-light">
          {firstMetric.label}
        </p>
        <p class="display-sm text-accent">{firstMetric.value}</p>
      </div>
    )}

    <div class="flex items-center gap-2 font-mono text-[0.74rem] uppercase tracking-[0.18em] text-primary">
      View case study
      <Icon name="workflow" size={16} class="text-accent" />
    </div>
  </div>
</Card>
