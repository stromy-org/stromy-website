---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";

interface Props {
  title: string;
  capability: string;
  client: string;
  slug: string;
  image: ImageMetadata;
  region: string;
  metrics?: { label: string; value: string }[];
}

const { title, capability, client, slug, image, region, metrics = [] } = Astro.props;

const firstMetric = metrics.length > 0 ? metrics[0] : null;
---

<Card href={`/case-studies/${slug}`}>
  <div class="flex flex-col gap-4">
    {/* Image with brutalist overlay */}
    <div class="brutalist-overlay overflow-hidden rounded-lg h-48">
      <Image
        src={image}
        alt={title}
        class="h-full w-full object-cover"
        widths={[400, 640]}
        sizes="(max-width: 768px) 100vw, 33vw"
      />
    </div>

    {/* Badges */}
    <div class="flex flex-wrap items-center gap-2">
      <Badge text={capability} variant="primary" />
      <Badge text={region} variant="muted" />
    </div>

    {/* Title */}
    <h3 class="display-sm text-primary">{title}</h3>

    {/* Client */}
    <p class="body-sm text-text-light">{client}</p>

    {/* First metric highlight */}
    {firstMetric && (
      <div class="mt-auto border-t border-ash pt-4">
        <p class="mono text-xs uppercase tracking-wider text-text-light">
          {firstMetric.label}
        </p>
        <p class="display-sm text-accent">{firstMetric.value}</p>
      </div>
    )}
  </div>
</Card>
