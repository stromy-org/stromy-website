---
// Region toggle — renders a Preact island for interactive region switching.
// Falls back to static AU | NL display without JS.
---

<div class="region-toggle" data-region-toggle>
  <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/4 p-1 font-mono text-[0.7rem] uppercase tracking-[0.2em] text-background/68">
    <button
      data-region="AU"
      class="region-btn rounded-full px-3 py-1.5 transition-colors hover:text-background"
      aria-label="Switch to Australia region"
    >
      AU
    </button>
    <button
      data-region="NL"
      class="region-btn rounded-full px-3 py-1.5 transition-colors hover:text-background"
      aria-label="Switch to Netherlands region"
    >
      NL
    </button>
  </div>
</div>

<style>
  .region-btn.region-active {
    background-color: var(--color-accent);
    color: var(--color-background);
    font-weight: 600;
  }
</style>

<script is:inline>
  function initRegionToggle() {
    document.querySelectorAll("[data-region-toggle]").forEach(function (container) {
      var buttons = container.querySelectorAll("[data-region]");
      var stored = localStorage.getItem("region") || "AU";

      buttons.forEach(function (btn) {
        if (btn.getAttribute("data-region") === stored) {
          btn.classList.add("region-active");
        } else {
          btn.classList.remove("region-active");
        }

        btn.addEventListener("click", function () {
          var region = btn.getAttribute("data-region");
          localStorage.setItem("region", region);
          buttons.forEach(function (b) { b.classList.remove("region-active"); });
          btn.classList.add("region-active");
        });
      });
    });
  }
  initRegionToggle();
  document.addEventListener("astro:after-swap", initRegionToggle);
</script>
