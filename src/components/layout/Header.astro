---
import Nav from "./Nav.astro";
import RegionToggle from "./RegionToggle.astro";
import { mainNav } from "../../data/site";
import logoWhite from "../../brand/logos/logo_white.svg";
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-secondary/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-8 px-6 py-4">
    <a href="/" class="flex shrink-0 items-center gap-3" aria-label="Stromy — Home">
      <img
        src={logoWhite.src}
        alt="Stromy"
        class="h-8 w-auto"
      />
      <span class="hidden font-mono text-[0.72rem] uppercase tracking-[0.26em] text-background/58 xl:block">
        Intelligence Systems
      </span>
    </a>

    <div class="hidden items-center gap-7 lg:flex">
      <Nav items={mainNav} />
      <RegionToggle />
      <a
        href="/contact"
        class="inline-flex items-center rounded-full border border-white/14 px-4 py-2 font-mono text-[0.72rem] font-medium uppercase tracking-[0.24em] text-background transition-colors hover:border-accent hover:text-accent"
      >
        Contact
      </a>
    </div>

    <details class="group lg:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer items-center justify-center rounded-full border border-white/12 text-background transition-colors hover:border-accent hover:text-accent list-none [&::-webkit-details-marker]:hidden"
        aria-label="Toggle menu"
      >
        <svg class="h-6 w-6 group-open:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
        <svg class="hidden h-6 w-6 group-open:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </summary>

      <div class="absolute inset-x-0 top-full border-b border-white/10 bg-secondary/98 px-6 pb-6 pt-4 shadow-2xl">
        <nav class="flex flex-col gap-2">
          {mainNav.map((item) => (
            <a
              href={item.href}
              class="block rounded-2xl border border-white/5 px-4 py-3 font-mono text-sm uppercase tracking-[0.18em] text-background/82 transition-colors hover:border-accent/35 hover:text-background"
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="mt-6 flex items-center justify-between border-t border-white/10 pt-4">
          <RegionToggle />
          <a
            href="/contact"
            class="inline-flex items-center rounded-full border border-white/14 px-4 py-2 font-mono text-[0.72rem] font-medium uppercase tracking-[0.2em] text-background transition-colors hover:border-accent hover:text-accent"
          >
            Contact
          </a>
        </div>
      </div>
    </details>
  </div>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-[81px]" aria-hidden="true"></div>
