---
import type { NavItem } from "../../data/site";

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<nav aria-label="Main navigation">
  <ul class="flex items-center gap-6">
    {items.map((item) => (
      <li>
        <a
          href={item.href}
          class:list={[
            "relative whitespace-nowrap py-1 font-mono text-[0.74rem] uppercase tracking-[0.22em] text-background/72 transition-colors hover:text-background",
            "after:absolute after:inset-x-0 after:-bottom-3 after:h-[2px] after:origin-left after:scale-x-0 after:bg-accent after:transition-transform hover:after:scale-x-100",
            { "text-background after:scale-x-100": isActive(item.href) },
          ]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
