---
import { site, footerNav } from "../../data/site";
import logoWhite from "../../brand/logos/logo_white.svg";

const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary text-background">
  <div class="mx-auto max-w-7xl px-6">
    <div class="score-line border-t border-white/0" aria-hidden="true"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 py-18">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1.3fr_0.8fr_0.8fr_0.8fr]">
      <div class="max-w-sm">
        <a href="/" aria-label="Stromy — Home" class="inline-flex items-center gap-3">
          <img
            src={logoWhite.src}
            alt="Stromy"
            class="h-8 w-auto"
          />
        </a>
        <p class="mt-5 font-mono text-[0.72rem] uppercase tracking-[0.26em] text-background/58">
          {site.tagline}
        </p>
        <p class="body-md mt-5 max-w-xs text-background/72">
          {site.description}
        </p>
        <a
          href="/contact"
          class="mt-8 inline-flex items-center rounded-full border border-white/14 px-5 py-2.5 font-mono text-[0.74rem] uppercase tracking-[0.2em] text-background transition-colors hover:border-accent hover:text-accent"
        >
          Start a Conversation
        </a>
      </div>

      <div>
        <h4 class="mb-4 font-mono text-[0.72rem] font-medium uppercase tracking-[0.24em] text-background/56">
          Navigation
        </h4>
        <ul class="space-y-3">
          {footerNav.services.map((item) => (
            <li>
              <a
                href={item.href}
                class="body-sm text-background/72 transition-colors hover:text-background"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="mb-4 font-mono text-[0.72rem] font-medium uppercase tracking-[0.24em] text-background/56">
          Company
        </h4>
        <ul class="space-y-3">
          {footerNav.company.map((item) => (
            <li>
              <a
                href={item.href}
                class="body-sm text-background/72 transition-colors hover:text-background"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="mb-4 font-mono text-[0.72rem] font-medium uppercase tracking-[0.24em] text-background/56">
          Contact
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              href={`mailto:${site.email}`}
              class="body-sm text-background/72 transition-colors hover:text-background"
            >
              {site.email}
            </a>
          </li>
          <li class="body-sm text-background/52">
            Melbourne and Amsterdam
          </li>
        </ul>

        <h4 class="mb-4 mt-8 font-mono text-[0.72rem] font-medium uppercase tracking-[0.24em] text-background/56">
          Legal
        </h4>
        <ul class="space-y-3">
          {footerNav.legal.map((item) => (
            <li>
              <a
                href={item.href}
                class="body-sm text-background/72 transition-colors hover:text-background"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row sm:items-center">
      <p class="font-mono text-[0.72rem] uppercase tracking-[0.2em] text-background/48">
        &copy; {currentYear} {site.name}. All rights reserved.
      </p>
      <p class="font-heading text-lg italic text-background/68">
        Intelligence, Orchestrated.
      </p>
    </div>
  </div>
</footer>
