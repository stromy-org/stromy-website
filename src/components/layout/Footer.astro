---
import { site, footerNav } from "../../data/site";

const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary text-background">
  <!-- Score line divider -->
  <div class="score-line mx-auto max-w-7xl" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Company info -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" aria-label="Stromy — Home">
          <img
            src="/brand/logos/logo_white.svg"
            alt="Stromy"
            class="mb-4 h-8 w-auto"
          />
        </a>
        <p class="body-sm text-ash max-w-xs">
          {site.tagline}
        </p>
        <p class="body-sm text-text-light mt-4">
          {site.description}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-ash">
          Navigation
        </h4>
        <ul class="space-y-3">
          {footerNav.services.map((item) => (
            <li>
              <a
                href={item.href}
                class="body-sm text-text-light transition-colors hover:text-accent"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-ash">
          Company
        </h4>
        <ul class="space-y-3">
          {footerNav.company.map((item) => (
            <li>
              <a
                href={item.href}
                class="body-sm text-text-light transition-colors hover:text-accent"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & Legal -->
      <div>
        <h4 class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-ash">
          Contact
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              href={`mailto:${site.email}`}
              class="body-sm text-text-light transition-colors hover:text-accent"
            >
              {site.email}
            </a>
          </li>
        </ul>

        <h4 class="mb-4 mt-8 font-mono text-xs font-medium uppercase tracking-widest text-ash">
          Legal
        </h4>
        <ul class="space-y-3">
          {footerNav.legal.map((item) => (
            <li>
              <a
                href={item.href}
                class="body-sm text-text-light transition-colors hover:text-accent"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 border-t border-graphite pt-8 flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="font-mono text-xs text-text-light">
        &copy; {currentYear} {site.name}. All rights reserved.
      </p>
      <p class="font-heading text-sm italic text-ash">
        Intelligence, Orchestrated.
      </p>
    </div>
  </div>
</footer>
