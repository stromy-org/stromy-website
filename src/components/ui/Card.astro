---
interface Props {
  variant?: 'light' | 'dark';
  href?: string;
  class?: string;
}

const { variant = 'light', href, class: className = '' } = Astro.props;

const variantClasses: Record<string, string> = {
  light: 'surface-panel text-[#0B0B0B]',
  dark: 'dark-panel text-[#F2F0EA]',
};

const baseClasses = 'rounded-[1.75rem] p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl';
const classes = [baseClasses, variantClasses[variant], className].join(' ');
---

{href ? (
  <a href={href} class={`block ${classes}`}>
    <slot />
  </a>
) : (
  <div class={classes}>
    <slot />
  </div>
)}
