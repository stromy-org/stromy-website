---
interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = '' } = Astro.props;
---

<span
  class:list={['inline-flex items-center justify-center', className]}
  style={`width: ${size}px; height: ${size}px; font-size: ${size * 0.6}px;`}
  aria-hidden="true"
  data-icon={name}
>
  {name}
</span>
