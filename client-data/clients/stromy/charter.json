  "website": {
    "archetype": "sage",
    "aesthetic": "editorial-systems",
    "layout": {
      "density": "measured",
      "symmetry": "balanced",
      "flowDirection": "stack",
      "heroStyle": "editorial-stack",
      "gridSystem": "structured-2col",
      "sectionSpacing": "generous",
      "sectionDividers": "motif-band",
      "footerStyle": "indexed",
      "whitespaceStrategy": "measured"
    },
    "texture": {
      "backgroundTreatment": "solid",
      "surfaceFinish": "matte",
      "borderStyle": "thin-line",
      "shadowDepth": "none",
      "cornerRadius": "sharp",
      "overlayStyle": "brand-tint",
      "patternDensity": "none"
    },
    "typography": {
      "headingStyle": "display-serif",
      "headingScale": 1.35,
      "bodyLineHeight": 1.7,
      "letterSpacing": "tight",
      "textTransform": "none",
      "pullQuoteStyle": "serif-led",
      "listStyle": "mono-indexed"
    },
    "motion": {
      "intensity": "moderate",
      "revealStyle": "clip-reveal",
      "scrollBehavior": "smooth",
      "hoverBehavior": "color-shift",
      "transitionSpeed": "cinematic",
      "loadingAnimation": "stagger-fade",
      "cursorStyle": "default"
    },
    "components": {
      "navigation": "sticky-minimal",
      "cards": "bordered",
      "buttons": "outline",
      "forms": "minimal-underline",
      "imagePresentation": "full-bleed",
      "testimonials": "quote-panel",
      "ctaStyle": "inline",
      "socialProof": "case-facts",
      "codeBlocks": "terminal-style"
    },
    "colorApplication": {
      "darkSections": true,
      "darkSectionFrequency": 3,
      "accentUsage": "balanced",
      "gradientDirection": "none",
      "colorBlockSections": true,
      "imageOverlayBehavior": "brand-tint"
    },
    "pages": {
      "home": {
        "enabled": true,
        "sections": [
          { "type": "hero", "variant": "split" },
          { "type": "service", "variant": "capability-grid" },
          { "type": "stats", "variant": "counter-band" },
          { "type": "case-study", "variant": "featured-card" },
          { "type": "content", "variant": "tech-teaser" },
          { "type": "cta", "variant": "full-width-band" }
        ]
      },
      "about": { "enabled": true },
      "services": { "enabled": true },
      "case-studies": { "enabled": true },
      "blog": { "enabled": true },
      "contact": { "enabled": true }
    },
    "deployment": {
      "platform": "github-pages",
      "domain": "stromy.com.au",
      "analytics": "plausible",
      "contactForm": "formspree"
    }
  },
  "document": {
    "margins": { "top": "1in", "bottom": "1in", "left": "1in", "right": "1in" },
    "header": { "content": "STROMY", "logo": true },
    "footer": { "content": "Confidential", "pageNumbers": true },
    "headingColor": "primary",
    "tableHeaderColor": "primary"
  },
  "presentation": {
    "slideMargin": "40pt",
    "titleMargin": "30pt",
    "contentMargin": "20pt",
    "aspectRatio": "16:9"
  },
  "video": {
    "resolution": "1920x1080",
    "fps": 30
  },
  "formatting": {
    "headingThreshold": 24,
    "accentCycleColors": ["primary", "accent", "success"],
    "autoContrastText": true
  },
  "plotly": {
    "categoricalPalette": ["#1D342B", "#B96034", "#47685B", "#7F9B90", "#D68A60", "#6D665C"],
    "defaultHeight": 500,
    "titleFontSize": 18,
    "axisFontSize": 12,
    "legendFontSize": 11,
    "margins": { "top": 80, "bottom": 70, "left": 60, "right": 50 },
    "baseTemplate": "plotly_white",
    "gridColor": "#D7D0C3",
    "secondaryTextColor": "#8C857A",
    "bar": {
      "markerColor": "#1D342B",
      "markerLineColor": "#152019",
      "markerLineWidth": 1
    },
    "line": {
      "color": "#1D342B",
      "width": 2.5,
      "markerColor": "#B96034",
      "markerSize": 7
    },
    "scatter": {
      "markerColor": "#1D342B",
      "markerSize": 8,
      "markerLineWidth": 0
    },
    "pie": {
      "hole": 0.4,
      "textfontSize": 13,
      "markerLineColor": "#ECE6DA",
      "markerLineWidth": 2
    },
    "sentiment": {
      "positiveColor": "#47685B",
      "neutralColor": "#8C857A",
      "negativeColor": "#8E3F2E"
    }
  },
  "placeholderPolicy": {
    "brandFields": ["brandName", "tagline", "domain", "logoPath"],
    "externalFields": ["sender.name", "sender.title", "sender.email", "sender.phone", "sender.mobile", "sender.address"],
    "fallback": "placeholders",
    "placeholderFormat": "{{fieldName}}"
  }
}
